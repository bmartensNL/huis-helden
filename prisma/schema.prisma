generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id        String   @id @default(uuid())
  pin       String
  createdAt DateTime @default(now())
  children  Child[]
  tasks     Task[]
  rewards   Reward[]
}

model Child {
  id             String           @id @default(uuid())
  familyId       String
  family         Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name           String
  avatar         String           @default("🦸")
  xp             Int              @default(0)
  maxXp          Int              @default(100)
  level          Int              @default(1)
  streak         Int              @default(0)
  coins          Int              @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime         @default(now())
  assignedTasks  Task[]           @relation("AssignedTasks")
  completions    TaskCompletion[]
  badges         Badge[]
  rewardClaims   RewardClaim[]
}

model Task {
  id           String           @id @default(uuid())
  familyId     String
  family       Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name         String
  emoji        String           @default("📋")
  xp           Int              @default(10)
  coins        Int              @default(1)
  difficulty   String           @default("easy") // easy, medium, hard
  duration     Int?             // minutes
  deadline     DateTime?
  assignedToId String?
  assignedTo   Child?           @relation("AssignedTasks", fields: [assignedToId], references: [id])
  recurring    String?          // daily, weekly, weekdays, weekend
  isBonus      Boolean          @default(false)
  createdAt    DateTime         @default(now())
  completions  TaskCompletion[]
}

model TaskCompletion {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([taskId, childId, completedAt])
}

model Reward {
  id       String        @id @default(uuid())
  familyId String
  family   Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  emoji    String        @default("🎁")
  name     String
  cost     Int
  claims   RewardClaim[]
}

model RewardClaim {
  id        String   @id @default(uuid())
  rewardId  String
  reward    Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  claimedAt DateTime @default(now())
}

model Badge {
  id        String   @id @default(uuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  badgeType String   // first_task, streak_master, hard_worker, speedster, task_thief, legend
  earnedAt  DateTime @default(now())

  @@unique([childId, badgeType])
}
